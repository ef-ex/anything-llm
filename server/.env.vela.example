# Vela Integration — add these to your server/.env file when running AnythingLLM

# URL of the Vela Hub backend (default: http://127.0.0.1:7700)
VELA_API_URL=http://127.0.0.1:7700

# Optional: dev/bootstrap fallback project ID (resolved server-side; prefer workspace.velaProjectId)
VELA_PROJECT_ID=

# Optional: timeout for Vela API calls in ms (default: 5000)
VELA_TIMEOUT_MS=5000